{:paths ["src" "test" "bench"]

 :tasks
 {format
  {:doc "Format CSV, TSV, or whitespace input with clj-string-layout.cli"
   :task (apply shell "clojure" "-M:cli" *command-line-args*)}

  bb-format
  {:doc "Format input using Babashka directly (no JVM startup)"
   :requires ([clj-string-layout.cli :as cli])
   :task (apply cli/-main *command-line-args*)}

  bb-test
  {:doc "Run the bb-compatible test suite under Babashka"
   :requires ([clj-string-layout.bb-test-runner])
   :task (clj-string-layout.bb-test-runner/-main)}

  bb-bench
  {:doc "Run benchmarks natively under Babashka (no JVM startup)"
   :requires ([clj-string-layout.bench])
   :task (clj-string-layout.bench/-main)}

  test
  {:doc "Run the Clojure test suite"
   :task (shell "clojure -M:test")}

  lint
  {:doc "Run clj-kondo"
   :task (shell "clojure -M:lint")}

  bench
  {:doc "Run repeatable benchmarks"
   :task (shell "clojure -M:bench")}

  jar
  {:doc "Build the jar"
   :task (shell "clojure -T:build jar")}}}
