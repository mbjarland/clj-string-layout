{:paths ["src"]

 :deps {org.clojure/clojure {:mvn/version "1.12.5"}
        instaparse/instaparse {:mvn/version "1.5.0"}}

 :aliases
 {:test
  {:extra-paths ["test"]
   :extra-deps {org.clojure/test.check {:mvn/version "1.1.3"}}
   :main-opts ["-m" "clj-string-layout.test-runner"]}

  :cli
  {:main-opts ["-m" "clj-string-layout.cli"]}

  :bench
  {:extra-paths ["bench"]
   :main-opts ["-m" "clj-string-layout.bench"]}

  :lint
  {:extra-deps {clj-kondo/clj-kondo {:mvn/version "2026.04.15"}}
   :main-opts ["-m" "clj-kondo.main" "--lint" "src" "test" "bench" "build.clj"]}

  :build
  {:deps {io.github.clojure/tools.build {:mvn/version "0.10.13"}}
   :ns-default build}

  :deploy
  {:deps {io.github.clojure/tools.build {:mvn/version "0.10.13"}
          slipset/deps-deploy {:mvn/version "0.2.4"}}
   :ns-default build}}}
